---
/**
 * Permalink redirect pages for SEO-friendly URLs like:
 * /linkedin-pinpoint-answer-for-may-17-2026
 *
 * These pages:
 * - Have noindex + canonical to /archive (avoid duplicate content)
 * - Use sessionStorage to pass the date to /archive
 * - Redirect to clean /archive URL via JS
 * - Show a brief loading state for users without JS
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildMeta, breadcrumbJsonLd, SITE_URL } from '../lib/seo';
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  const MONTH_NAMES = ['january','february','march','april','may','june','july','august','september','october','november','december'];
  const archivePath = path.join(process.cwd(), 'public/data/archive.json');
  let archiveData: { number: number; date: string; clues: string[]; answer: string | null }[] = [];
  try {
    const raw = fs.readFileSync(archivePath, 'utf-8');
    archiveData = JSON.parse(raw);
  } catch (e) {
    console.error(`[permalink] Failed to read archive.json:`, e.message);
  }

  const paths = [];
  for (const puzzle of archiveData) {
    const date = new Date(puzzle.date + 'T00:00:00');
    const monthName = MONTH_NAMES[date.getMonth()];
    const day = date.getDate();
    const year = date.getFullYear();
    const slug = `linkedin-pinpoint-answer-for-${monthName}-${day}-${year}`;
    paths.push({
      params: { permalink: slug },
      props: { date: puzzle.date, number: puzzle.number, answer: puzzle.answer, clues: puzzle.clues }
    });
  }
  console.log(`[permalink] Generated ${paths.length} permalink pages`);
  return paths;
}

const { date, number, answer, clues } = Astro.props;
const shortDateStr = new Date(date + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const seo = buildMeta({
  title: `LinkedIn Pinpoint #${number} Answer — ${shortDateStr}`,
  description: `The answer to LinkedIn Pinpoint #${number} for ${shortDateStr} is ${answer || 'available in our archive'}. See all clues, explanations, and valid solutions.`,
  keywords: `LinkedIn Pinpoint #${number}, ${answer}, pinpoint answer ${date}, LinkedIn puzzle`,
  canonical: `${SITE_URL}/archive`,
  noindex: true,
  jsonLd: [
    breadcrumbJsonLd([
      { name: 'Home', url: SITE_URL },
      { name: 'Archive', url: `${SITE_URL}/archive` }
    ])
  ]
});
---
<BaseLayout {...seo}>
  <div class="container" style="padding: 4rem 1rem; text-align: center;">
    <div class="loading-spinner" style="margin: 0 auto 1rem;"></div>
    <h1>LinkedIn Pinpoint #{number} — {shortDateStr}</h1>
    <p style="color: var(--text-secondary); margin: 0.5rem 0 1.5rem;">Redirecting to the archive...</p>
    <a href="/archive" class="btn btn-primary">Go to Archive</a>
  </div>
  <script define:vars={{ date }}>
    // Pass the date to the archive page via sessionStorage, then redirect
    try {
      sessionStorage.setItem('pinpoint-open-date', date);
    } catch(e) {}
    window.location.replace('/archive');
  </script>
</BaseLayout>
